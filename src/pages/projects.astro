---
import Layout from "../components/layout.astro";
import IndexIcon from "../components/icons/Index.astro";
import Link from "../components/icons/Link.astro";
import { fetchStars, formatStars } from "../lib/github-stars";

const repoMap: Record<string, string> = {
  "zk-email-verify": "zkemail/zk-email-verify",
  "zk-regex v2": "zkemail/zk-regex",
  "jwt-tx-builder": "zkemail/email-tx-builder",
  "ProveKit": "worldfnd/provekit",
  "WHIR": "WizardOfMenlo/whir",
};

const starCounts = await Promise.all(
  Object.entries(repoMap).map(async ([label, repo]) => {
    const count = await fetchStars(repo);
    return [label, count] as const;
  }),
);
const liveStars = Object.fromEntries(starCounts);

const projects = [
  {
    label: "zk-email-verify",
    href: "https://github.com/zkemail/zk-email-verify",
    description:
      "Verify any text in any sent or received email, cryptographically — trusting only the sending mailserver.",
    role: "Core contributor @ ZkEmail",
    stars: formatStars(liveStars["zk-email-verify"], "420+"),
  },
  {
    label: "zk-regex v2",
    href: "https://github.com/zkemail/zk-regex",
    description:
      "Regex-to-circuit compiler (Circom/Noir) with off-circuit NFA traversal and in-circuit proof.",
    role: "Author @ ZkEmail",
    stars: formatStars(liveStars["zk-regex v2"], "100+"),
  },
  {
    label: "jwt-tx-builder",
    href: "https://github.com/zkemail/email-tx-builder",
    description:
      "Proving OAuth identity (e.g., Google Workspace membership) via JWT verification in ZK.",
    role: "Author @ ZkEmail",
    stars: formatStars(liveStars["jwt-tx-builder"], "80+"),
  },
  {
    label: "ProveKit",
    href: "https://github.com/worldfnd/provekit",
    description: "Client-side zero-knowledge proving.",
    role: "Contributor @ World",
    stars: formatStars(liveStars["ProveKit"], "100+"),
  },
  {
    label: "WHIR",
    href: "https://github.com/WizardOfMenlo/whir",
    description:
      "Reed–Solomon proximity testing with super-fast verification. Added batch prove/verify and enabled recursive verification by fixing transcript to constant length.",
    role: "Contributor",
    stars: formatStars(liveStars["WHIR"], "180+"),
  },
  {
    label: "ZkSnap",
    href: null,
    description:
      "Privacy-preserving voting protocol using IVC-based proof aggregation and additive homomorphic encryption. Built full Halo2 circuit stack with client-side proof generation under 30s.",
    role: "Author @ Aerius Labs",
    stars: null,
  },
  {
    label: "zkFOCIL",
    href: null,
    description:
      "ZK circuit to anonymize Ethereum FOCIL includer identities, replacing public signatures with proofs to prevent coercion/legal targeting. Built using Barretenberg stdlib and Ultra Honk.",
    role: "Ethereum Foundation grant",
    stars: null,
  },
  {
    label: "PLUME",
    href: null,
    description:
      "Plume nullifier scheme + secp256k1 hash-to-curve in Halo2 for anonymous double-spend prevention. Passed PSE audit.",
    role: "PSE grant",
    stars: null,
  },
];
---

<Layout
  title="Projects"
  description="Open source projects and contributions by Shreyas Londhe."
>
  <main class="relative">
    <div class="mb-4 lg:absolute lg:-ml-36 lg:mb-0 lg:h-full">
      <a class="exclude flex items-center gap-x-1 lg:sticky lg:top-8" href="/"
        ><IndexIcon /> Index
      </a>
    </div>
    <header>
      <h2 class="mb-6 font-semibold">Projects</h2>
    </header>
    <ul class="flex flex-col gap-y-6">
      {
        projects.map((project) => (
          <li class="border-l-2 border-transparent pl-3 transition-colors hover:border-blue-400">
            <div class="flex items-center gap-x-2">
              {project.href ? (
                <a
                  href={project.href}
                  rel="noreferrer"
                  target="_blank"
                  class="flex w-fit items-center font-medium"
                >
                  {project.label}
                  <Link />
                </a>
              ) : (
                <span class="font-medium">{project.label}</span>
              )}
              {project.stars && (
                <span class="rounded border border-blue-200 px-1.5 py-0.5 text-xs text-blue-500 dark:border-blue-900 dark:text-blue-400">
                  {project.stars} ★
                </span>
              )}
            </div>
            <p class="mt-0.5 text-sm text-neutral-500 dark:text-neutral-400">
              {project.role}
            </p>
            <p class="mt-1 leading-snug font-light text-neutral-500 dark:text-neutral-400">
              {project.description}
            </p>
          </li>
        ))
      }
    </ul>
  </main>
</Layout>
