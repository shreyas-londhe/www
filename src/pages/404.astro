---
import Layout from "../components/layout.astro";
import Index from "../components/icons/Index.astro";
---

<Layout title="Page Not Found">
  <main class="relative">
    <div class="mb-4 lg:absolute lg:-ml-36 lg:mb-0 lg:h-full">
      <a class="exclude flex items-center lg:sticky lg:top-8" href="/">
        <Index />
        Index
      </a>
    </div>
    <header>
      <h1 class="font-semibold">404—not found</h1>
      <p class="mt-6 font-light leading-snug">
        This page doesn't exist. <a href="/">Head back home</a>.
      </p>
    </header>
  </main>
</Layout>
