---
import Layout from "../../components/layout.astro";
import IndexIcon from "../../components/icons/Index.astro";

const postModules = import.meta.glob<{
  frontmatter: {
    title: string;
    description: string;
    pubDate: string;
    tags: string[];
  };
}>("./*.mdx", { eager: true });

const posts = Object.entries(postModules)
  .map(([path, post]) => ({
    ...post,
    url: path.replace(".mdx", "").replace("./", "/writing/"),
  }))
  .sort(
    (a, b) =>
      new Date(b.frontmatter.pubDate).valueOf() -
      new Date(a.frontmatter.pubDate).valueOf()
  );
---

<Layout title="Writing">
  <main class="relative">
    <div class="mb-4 lg:absolute lg:-ml-36 lg:mb-0 lg:h-full">
      <a class="exclude flex items-center gap-x-1 lg:sticky lg:top-8" href="/"
        ><IndexIcon /> Index
      </a>
    </div>
    <header>
      <h2 class="mb-6 font-semibold">Writing</h2>
    </header>
    {posts.length === 0 ? (
      <p class="font-light text-neutral-500 dark:text-neutral-400">
        Nothing here yet. Check back soon.
      </p>
    ) : (
    <ul class="flex flex-col gap-y-6">
      {
        posts.map((post, index) => {
          const date = new Date(post.frontmatter.pubDate);
          const year = date.getFullYear();
          const prevPost = posts[index - 1];
          const prevYear = prevPost
            ? new Date(prevPost.frontmatter.pubDate).getFullYear()
            : null;
          const showYear = year !== prevYear;

          return (
            <>
              {showYear && (
                <li class="text-sm font-medium text-neutral-400 dark:text-neutral-500">
                  {year}
                </li>
              )}
              <li>
                <a
                  href={post.url}
                  class="exclude block border-l-2 border-transparent pl-3 transition-colors hover:border-blue-400"
                >
                  <span class="font-medium text-neutral-900 dark:text-neutral-100">
                    {post.frontmatter.title}
                  </span>
                  <p class="mt-1 leading-snug font-light text-neutral-500 dark:text-neutral-400">
                    {post.frontmatter.description}
                  </p>
                  <div class="mt-2 flex flex-wrap items-center gap-2">
                    {post.frontmatter.tags?.map((tag) => (
                      <span class="rounded border border-blue-200 px-1.5 py-0.5 text-xs text-blue-500 dark:border-blue-900 dark:text-blue-400">
                        {tag}
                      </span>
                    ))}
                    <span class="text-sm text-neutral-400 dark:text-neutral-500">
                      {date.toLocaleDateString("en-US", {
                        month: "short",
                        day: "numeric",
                        year: "numeric",
                      })}
                    </span>
                  </div>
                </a>
              </li>
            </>
          );
        })
      }
    </ul>
    )}
  </main>
</Layout>
