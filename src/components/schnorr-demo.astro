---

---

<div class="not-prose" id="schnorr-demo">
  <div class="mb-4 flex items-center justify-between">
    <div class="flex gap-1" id="step-indicators">
      {[0, 1, 2, 3, 4].map((i) => (
        <div
          class="h-1.5 w-6 rounded-full bg-neutral-300 transition-colors dark:bg-neutral-700"
          data-step-dot={i}
        />
      ))}
    </div>
    <span class="text-xs text-neutral-500 dark:text-neutral-400" id="step-label">
      Step 0 / 4
    </span>
  </div>

  <div class="grid grid-cols-1 gap-3 sm:grid-cols-[1fr_auto_1fr]">
    <!-- Prover -->
    <div class="rounded-lg border border-neutral-200 p-4 dark:border-neutral-700">
      <h3 class="mb-3 text-sm font-semibold uppercase tracking-wide text-neutral-500 dark:text-neutral-400">
        Prover
      </h3>
      <div id="prover-content" class="space-y-2 text-sm"></div>
    </div>

    <!-- Message Channel -->
    <div class="flex items-center justify-center sm:w-24">
      <div id="channel-content" class="flex w-full flex-col items-center gap-2 text-xs text-neutral-500 dark:text-neutral-400"></div>
    </div>

    <!-- Verifier -->
    <div class="rounded-lg border border-neutral-200 p-4 dark:border-neutral-700">
      <h3 class="mb-3 text-sm font-semibold uppercase tracking-wide text-neutral-500 dark:text-neutral-400">
        Verifier
      </h3>
      <div id="verifier-content" class="space-y-2 text-sm"></div>
    </div>
  </div>

  <div id="step-explanation" class="mt-4 rounded-lg bg-neutral-200/50 p-3 text-sm dark:bg-neutral-800/50"></div>

  <div class="mt-4 flex items-center justify-between">
    <button
      id="btn-back"
      class="rounded-md border border-neutral-300 px-3 py-1.5 text-sm transition-colors hover:bg-neutral-200 disabled:opacity-40 disabled:hover:bg-transparent dark:border-neutral-600 dark:hover:bg-neutral-800 dark:disabled:hover:bg-transparent"
    >
      Back
    </button>
    <button
      id="btn-next"
      class="rounded-md bg-neutral-800 px-3 py-1.5 text-sm text-white transition-colors hover:bg-neutral-700 disabled:opacity-40 dark:bg-neutral-200 dark:text-neutral-900 dark:hover:bg-neutral-300"
    >
      Next
    </button>
  </div>
</div>

<style>
  .val-secret {
    background: rgb(239 68 68 / 0.1);
    border: 1px solid rgb(239 68 68 / 0.3);
    border-radius: 0.375rem;
    padding: 0.5rem 0.75rem;
  }
  .dark .val-secret {
    background: rgb(239 68 68 / 0.15);
    border-color: rgb(239 68 68 / 0.3);
  }
  .val-secret::before {
    content: "secret";
    display: block;
    font-size: 0.625rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: rgb(239 68 68 / 0.8);
    margin-bottom: 0.125rem;
  }
  .val-public {
    background: rgb(163 163 163 / 0.1);
    border: 1px solid rgb(163 163 163 / 0.2);
    border-radius: 0.375rem;
    padding: 0.5rem 0.75rem;
  }
  .dark .val-public {
    background: rgb(163 163 163 / 0.1);
    border-color: rgb(163 163 163 / 0.2);
  }
  .val-verify {
    background: rgb(34 197 94 / 0.1);
    border: 1px solid rgb(34 197 94 / 0.3);
    border-radius: 0.375rem;
    padding: 0.5rem 0.75rem;
  }
  .dark .val-verify {
    background: rgb(34 197 94 / 0.15);
    border-color: rgb(34 197 94 / 0.3);
  }
  .arrow-right, .arrow-left {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    white-space: nowrap;
  }
  .arrow-right .arrow-line, .arrow-left .arrow-line {
    height: 1px;
    width: 2rem;
    background: currentColor;
    position: relative;
  }
  .arrow-right .arrow-line::after {
    content: "";
    position: absolute;
    right: 0;
    top: -3px;
    border: 3px solid transparent;
    border-left-color: currentColor;
  }
  .arrow-left .arrow-line::before {
    content: "";
    position: absolute;
    left: 0;
    top: -3px;
    border: 3px solid transparent;
    border-right-color: currentColor;
  }
  @media (max-width: 639px) {
    .arrow-right, .arrow-left {
      flex-direction: row;
      justify-content: center;
    }
  }
</style>

<script>
  document.addEventListener("astro:page-load", () => {
    const demo = document.getElementById("schnorr-demo");
    if (!demo) return;

    const proverEl = document.getElementById("prover-content")!;
    const verifierEl = document.getElementById("verifier-content")!;
    const channelEl = document.getElementById("channel-content")!;
    const explanationEl = document.getElementById("step-explanation")!;
    const stepLabel = document.getElementById("step-label")!;
    const btnBack = document.getElementById("btn-back") as HTMLButtonElement;
    const btnNext = document.getElementById("btn-next") as HTMLButtonElement;
    const dots = demo.querySelectorAll("[data-step-dot]");

    const p = 23;
    const g = 5;

    function modPow(base: number, exp: number, mod: number): number {
      let result = 1;
      base = base % mod;
      let e = exp;
      while (e > 0) {
        if (e % 2 === 1) result = (result * base) % mod;
        e = Math.floor(e / 2);
        base = (base * base) % mod;
      }
      return result;
    }

    function randRange(min: number, max: number): number {
      return min + Math.floor(Math.random() * (max - min + 1));
    }

    function code(text: string): string {
      return `<code class="rounded bg-neutral-200 px-1 py-0.5 text-xs dark:bg-neutral-700">${text}</code>`;
    }

    function sup(base: string, exp: string): string {
      return `${base}<sup>${exp}</sup>`;
    }

    let step = 0;
    let x: number, y: number, r: number, t: number, c: number, s: number;

    function rollValues() {
      x = randRange(2, p - 2);
      y = modPow(g, x, p);
      r = randRange(2, p - 2);
      t = modPow(g, r, p);
      c = randRange(1, 10);
      s = (r + c * x) % (p - 1);
    }

    rollValues();

    function arrowRight(label: string): string {
      return `<div class="arrow-right"><span>${label}</span><span class="arrow-line"></span><span>→</span></div>`;
    }
    function arrowLeft(label: string): string {
      return `<div class="arrow-left"><span>←</span><span class="arrow-line"></span><span>${label}</span></div>`;
    }

    function render() {
      stepLabel.textContent = `Step ${step} / 4`;
      dots.forEach((dot, i) => {
        const el = dot as HTMLElement;
        if (i <= step) {
          el.className = "h-1.5 w-6 rounded-full bg-neutral-800 transition-colors dark:bg-neutral-200";
        } else {
          el.className = "h-1.5 w-6 rounded-full bg-neutral-300 transition-colors dark:bg-neutral-700";
        }
      });

      btnBack.disabled = step === 0;
      if (step === 4) {
        btnNext.textContent = "Try Again";
      } else {
        btnNext.textContent = "Next";
      }

      let proverHTML = "";
      let verifierHTML = "";
      let channelHTML = "";
      let explanation = "";

      if (step >= 0) {
        proverHTML += `<div class="val-public">Public params: ${code(`p = ${p}`)}, ${code(`g = ${g}`)}</div>`;
        proverHTML += `<div class="val-secret">x = ${code(String(x))}</div>`;
        proverHTML += `<div class="val-public">y = ${code(`${sup(`${g}`, `${x}`)} mod ${p} = ${y}`)}</div>`;

        verifierHTML += `<div class="val-public">Public params: ${code(`p = ${p}`)}, ${code(`g = ${g}`)}</div>`;
        verifierHTML += `<div class="val-public">y = ${code(String(y))}</div>`;

        channelHTML = arrowRight(`y = ${y}`);
        explanation = `<strong>Setup:</strong> The prover and verifier agree on public parameters <em>p</em> = ${p} (a prime) and <em>g</em> = ${g} (a generator). The prover picks a secret key <em>x</em> and publishes <em>y</em> = ${sup("g", "x")} mod <em>p</em>.`;
      }

      if (step >= 1) {
        proverHTML += `<div class="val-secret">r = ${code(String(r))}</div>`;
        proverHTML += `<div class="val-public">t = ${code(`${sup(`${g}`, `${r}`)} mod ${p} = ${t}`)}</div>`;

        verifierHTML += `<div class="val-public">t = ${code(String(t))}</div>`;

        channelHTML = arrowRight(`t = ${t}`);
        explanation = `<strong>Commit:</strong> The prover picks a random nonce <em>r</em> and computes a commitment <em>t</em> = ${sup("g", "r")} mod <em>p</em> = ${t}. This commitment is sent to the verifier.`;
      }

      if (step >= 2) {
        verifierHTML += `<div class="val-public" style="border-color: rgb(59 130 246 / 0.4); background: rgb(59 130 246 / 0.08);">c = ${code(String(c))}<span class="ml-1 text-xs text-blue-500">(challenge)</span></div>`;

        channelHTML = arrowLeft(`c = ${c}`);
        explanation = `<strong>Challenge:</strong> The verifier picks a random challenge <em>c</em> = ${c} and sends it back to the prover.`;
      }

      if (step >= 3) {
        proverHTML += `<div class="val-public">s = ${code(`r + c·x mod (p−1)`)}<br><span class="mt-1 inline-block">${code(`${r} + ${c}·${x} mod ${p - 1} = ${s}`)}</span></div>`;

        verifierHTML += `<div class="val-public">s = ${code(String(s))}</div>`;

        channelHTML = arrowRight(`s = ${s}`);
        explanation = `<strong>Response:</strong> The prover computes <em>s</em> = <em>r</em> + <em>c</em>·<em>x</em> mod (<em>p</em>−1) = ${r} + ${c}·${x} mod ${p - 1} = ${s}, and sends it to the verifier.`;
      }

      if (step >= 4) {
        const lhs = modPow(g, s, p);
        const rhs = (t * modPow(y, c, p)) % p;
        const ok = lhs === rhs;

        verifierHTML += `<div class="val-verify">
          <strong>Check:</strong> ${code(`${sup(`${g}`, `${s}`)} mod ${p}`)} = ${code(String(lhs))}<br>
          ${code(`t · ${sup(`y`, `${c}`)} mod ${p}`)} = ${code(`${t} · ${modPow(y, c, p)} mod ${p}`)} = ${code(String(rhs))}<br>
          <span class="mt-1 inline-block font-semibold ${ok ? "text-green-600 dark:text-green-400" : "text-red-600 dark:text-red-400"}">
            ${ok ? "✓ Verified — prover knows x" : "✗ Verification failed"}
          </span>
        </div>`;

        channelHTML = "";
        explanation = `<strong>Verify:</strong> The verifier checks if ${sup("g", "s")} mod <em>p</em> equals <em>t</em> · ${sup("y", "c")} mod <em>p</em>. Both sides equal ${lhs}, so the proof is ${ok ? "accepted" : "rejected"}. The prover never revealed <em>x</em>.`;
      }

      proverEl.innerHTML = proverHTML;
      verifierEl.innerHTML = verifierHTML;
      channelEl.innerHTML = channelHTML;
      explanationEl.innerHTML = explanation;
    }

    btnNext.addEventListener("click", () => {
      if (step === 4) {
        step = 0;
        rollValues();
      } else {
        step++;
      }
      render();
    });

    btnBack.addEventListener("click", () => {
      if (step > 0) {
        step--;
        render();
      }
    });

    render();
  });
</script>
