    { "id": "step6-box", "type": "rectangle", "x": 80, "y": 500, "width": 880, "height": 160, "angle": 0, "strokeColor": "#1971c2", "backgroundColor": "#d0ebff", "fillStyle": "hachure", "strokeWidth": 2, "roughness": 1, "opacity": 40, "roundness": {"type": 3}, "seed": 1032, "version": 1, "isDeleted": false, "boundElements": null, "updated": 1, "link": null, "locked": false, "groupIds": [] },
    { "id": "step6-title", "type": "text", "x": 280, "y": 514, "width": 480, "height": 28, "text": "Step 6 — Bundle into recursive CRS instance", "fontSize": 22, "fontFamily": 5, "textAlign": "center", "verticalAlign": "top", "angle": 0, "strokeColor": "#1971c2", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "roughness": 0, "opacity": 100, "roundness": null, "seed": 1033, "version": 1, "isDeleted": false, "boundElements": null, "updated": 1, "link": null, "locked": false, "groupIds": [] },
    { "id": "step6-eq1", "type": "text", "x": 100, "y": 552, "width": 840, "height": 24, "text": "ŵ′(Z, X) = ŵ(Z, α, X)  +  Z · Σᵢ₌₀ᵗ γⁱ⁺¹ · eq(𝐳ᵢ, X)", "fontSize": 18, "fontFamily": 5, "textAlign": "center", "verticalAlign": "top", "angle": 0, "strokeColor": "#1e1e1e", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "roughness": 0, "opacity": 100, "roundness": null, "seed": 1034, "version": 1, "isDeleted": false, "boundElements": null, "updated": 1, "link": null, "locked": false, "groupIds": [] },
    { "id": "step6-eq2", "type": "text", "x": 100, "y": 580, "width": 840, "height": 24, "text": "σ′ = ĥₖ(αₖ)  +  Σᵢ₌₀ᵗ γⁱ⁺¹ · yᵢ", "fontSize": 18, "fontFamily": 5, "textAlign": "center", "verticalAlign": "top", "angle": 0, "strokeColor": "#1e1e1e", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "roughness": 0, "opacity": 100, "roundness": null, "seed": 1035, "version": 1, "isDeleted": false, "boundElements": null, "updated": 1, "link": null, "locked": false, "groupIds": [] },
    { "id": "step6-recurse", "type": "text", "x": 100, "y": 610, "width": 840, "height": 22, "text": "recurse on  g ∈ C′ := CRS[F, L⁽²⁾, m−k, ŵ′, σ′]", "fontSize": 16, "fontFamily": 5, "textAlign": "center", "verticalAlign": "top", "angle": 0, "strokeColor": "#1971c2", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "roughness": 0, "opacity": 100, "roundness": null, "seed": 1036, "version": 1, "isDeleted": false, "boundElements": null, "updated": 1, "link": null, "locked": false, "groupIds": [] },
    { "id": "step6-rate", "type": "text", "x": 100, "y": 634, "width": 840, "height": 20, "text": "rate ρ′ = 2¹⁻ᵏ · ρ   ·   |L| halved   ·   m drops by k", "fontSize": 14, "fontFamily": 5, "textAlign": "center", "verticalAlign": "top", "angle": 0, "strokeColor": "#868e96", "backgroundColor": "transparent", "fillStyle": "solid", "strokeWidth": 1, "roughness": 0, "opacity": 100, "roundness": null, "seed": 1037, "version": 1, "isDeleted": false, "boundElements": null, "updated": 1, "link": null, "locked": false, "groupIds": [] },

